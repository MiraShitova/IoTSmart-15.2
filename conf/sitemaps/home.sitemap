sitemap home {
    Frame label="Моніторинг Теплиці" {
        Text item=Virtual_Temp label="Тестова температура [%.1f °C]" icon="temperature"
        
        Text item=Greenhouse_Hum label="Вологість повітря [%.1f %%]" icon="humidity"
    }

    Frame label="Керування" {
        // Кнопка для насоса
        Switch item=Greenhouse_Pump label="Полив" icon="faucet"
    }
}