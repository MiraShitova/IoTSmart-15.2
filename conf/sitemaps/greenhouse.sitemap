sitemap greenhouse {
    Frame label="Метрики теплиці" {
        Text item=Virtual_Temp valuecolor=[>25="red", >15="green", <=15="blue"]
        Text item=Greenhouse_Hum
        Text item=Soil_Moisture
        Text item=Light_Intensity
    }
    Frame label="Керування" {
        Switch item=Greenhouse_Pump
    }
}