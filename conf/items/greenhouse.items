Number Greenhouse_Temp "Температура MQTT [%.1f °C]" <temperature> { channel="mqtt:topic:mosquitto:greenhouse:temperature" }
Number Greenhouse_Hum  "Вологість [%.1f %%]"    <humidity>    { channel="mqtt:topic:mosquitto:greenhouse:humidity" }
Switch Greenhouse_Pump "Насос поливу"            <faucet>      { channel="mqtt:topic:mosquitto:greenhouse:pump" }

Number Soil_Moisture   "Вологість ґрунту [%.1f %%]" <moisture>
Number Light_Intensity "Освітленість [%.1f lx]"   <sun>
Number Virtual_Temp    "Тестова Температура [%.1f °C]" <temperature>