Number Greenhouse_Temp "Temperature [%.1f °C]" <temperature> { channel="mqtt:topic:mosquitto:greenhouse:temperature" }
Number Greenhouse_Hum  "Humidity [%.1f %%]"    <humidity>    { channel="mqtt:topic:mosquitto:greenhouse:humidity" }
Switch Greenhouse_Pump "Water Pump"            <faucet>      { channel="mqtt:topic:mosquitto:greenhouse:pump" }

Number Virtual_Temp "Test Temp [%.1f °C]" <temperature>