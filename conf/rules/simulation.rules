rule "Greenhouse Simulation"
when
    Time cron "0/30 * * * * ?"
then
    var Number currentTemp = 24.0
    if (Virtual_Temp.state instanceof Number) {
        currentTemp = Virtual_Temp.state as Number
    }
    
    var Number delta = (Math::random() - 0.5)
    var Number newTemp = currentTemp + delta

    if (newTemp < 18) newTemp = 18.5
    if (newTemp > 30) newTemp = 29.5

    Virtual_Temp.postUpdate(newTemp)
    
    var Number newHum = 40 + (Math::random() * 30)
    Greenhouse_Hum.postUpdate(newHum)

    logInfo("simulation", "Simulated Temp: " + newTemp + ", Hum: " + newHum)
end