rule "Greenhouse Advanced Simulation"
when
    Time cron "0/30 * * * * ?"
then
    val Double temp = 22.0 + (Math::random * 5.0)
    val Double hum = 45.0 + (Math::random * 15.0)
    val Double moisture = 40.0 + (Math::random * 30.0)
    val Double light = 200.0 + (Math::random * 400.0)

    Virtual_Temp.postUpdate(temp)
    Greenhouse_Hum.postUpdate(hum)
    Soil_Moisture.postUpdate(moisture)
    Light_Intensity.postUpdate(light)

    if (moisture < 50.0) {
        Greenhouse_Pump.postUpdate(ON)
    } else {
        Greenhouse_Pump.postUpdate(OFF)
    }

    logInfo("simulation", "Smart Greenhouse: T:" + temp + " H:" + hum + " Soil:" + moisture + " Pump:" + Greenhouse_Pump.state)
end