rule "Temperature Simulation Scenario"
when
    Item Start_Simulation received command ON
then
    logInfo("Simulation", "Сценарій імітації запущено...")

    logInfo("Simulation", "Крок 1: Відправка нормальних значень")
    Temperature_Sensor.sendCommand(22.5)
    
    Thread::sleep(5000)
    
    Temperature_Sensor.sendCommand(23.2)
    Thread::sleep(5000)

    logInfo("Simulation", "Крок 2: Імітація критичного збою!")
    Temperature_Sensor.sendCommand(48.7)
    
    Thread::sleep(7000) 
    logInfo("Simulation", "Крок 3: Повернення до стабільного стану")
    Temperature_Sensor.sendCommand(21.9)

    Start_Simulation.postUpdate(OFF)
    logInfo("Simulation", "Сценарій завершено.")
end